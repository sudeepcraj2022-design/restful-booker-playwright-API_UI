{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "baseUrl": ".", 
    "esModuleInterop": true,                  // Added for better library imports
    "skipLibCheck": true,                     // Added for faster, error-free runs
    "forceConsistentCasingInFileNames": true, // Added for Linux/CI compatibility
    "paths": {
      "@pages/*": [
        "pages/*"
      ],
      "@fixtures/*": [
        "fixtures/*"
      ],
      "@utils/*": [
        "utils/*"
      ],
      "@config/*": [
        "config/*"
      ],
      "@constants/*": [
        "constants/*"
      ],
      "@test-data/*": [
        "test-data/*"
      ],
      "@tests/*": [
        "tests/*"
      ]
    },
    "types": [
      "node",
      "@playwright/test"
    ],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "tests",
    "pages",
    "fixtures",
    "utils",
    "test-data",
    "config",
    "constants",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}